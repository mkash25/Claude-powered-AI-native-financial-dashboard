# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
# Project URL (format: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe for browser code
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key — used by /api/chat (server-side only, never exposed to browser)
ANTHROPIC_API_KEY=

# Supabase service role key — Mac sync scripts only (bypasses RLS, keep secret)
# Find in: Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
